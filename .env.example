# Claude Bridge configuration
#
# Copy this file to either:
#   ./.env                        (per-project override, takes priority)
#   ~/.claude-bridge/.env         (global default)
#
# Shell environment variables always win over both files.

# Port the bridge listens on
# BRIDGE_PORT=8787

# Path or name of the Claude CLI binary
# CLAUDE_CMD=claude

# Per-request timeout in milliseconds
# BRIDGE_TIMEOUT_MS=30000

# Claude model override (e.g. haiku for faster replies)
# BRIDGE_MODEL=haiku

# Shared secret for Authorization: Bearer <token> header.
# When set, all requests except OPTIONS and GET /health require it.
# BRIDGE_TOKEN=change-me-to-a-long-random-string
